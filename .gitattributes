# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized to LF.
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
*.db binary
*.sqlite binary
*.icns binary
*.lz4 binary

# Large research assets
fingerprint-data/build/* binary
fingerprint-data/dist/**/* binary
